{
  "name": "veripost",
  "version": "0.1.0",
  "private": true,
  "description": "World Mini App for verified-human proof links on X posts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kent/humanx.git"
  },
  "bugs": {
    "url": "https://github.com/kent/humanx/issues"
  },
  "homepage": "https://github.com/kent/humanx#readme",
  "keywords": [
    "world-id",
    "world-mini-app",
    "proof-of-human",
    "veripost",
    "nextjs"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node ./scripts/migrate-if-configured.mjs && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm verify:goals && pnpm build",
    "verify:goals": "vitest run src/lib/goals.test.ts",
    "verify:production-env": "node ./scripts/check-production-env.mjs",
    "deploy:production": "pnpm verify && pnpm verify:production-env && vercel deploy --prod",
    "db:migrate": "node ./scripts/migrate.mjs"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@worldcoin/idkit-core": "4.1.8",
    "@worldcoin/minikit-js": "2.0.3",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "postgres": "3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "viem": "2.51.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "happy-dom": "20.9.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.3.0"
}
